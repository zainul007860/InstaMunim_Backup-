                      <div className="flex items-center gap-4">
                        <div className="w-12 h-12 bg-orange-50 dark:bg-orange-900/20 rounded-2xl flex items-center justify-center font-black text-orange-600">{item.name.charAt(0)}</div>
                        <div>
                          <p className="font-black text-lg leading-none">{item.name}</p>
                          <p className="text-[10px] font-black text-zinc-400 uppercase tracking-widest mt-1.5">{item.category}</p>
                        </div>
                      </div>
                      <div className="flex items-center gap-6">
                        <p className="font-black text-xl tracking-tight">₹{item.price}</p>
                        <button onClick={() => setMenuItems(menuItems.filter(mi => mi.id !== item.id))} className="text-zinc-300 hover:text-red-500 transition-colors p-2">
                          <Trash2 className="h-5 w-5" />
                        </button>
                      </div>
                    </div>
                  ))}
                </div>
              </Card>
            </div>
          )}

          {activeTab === "Legal" && (
            <div className="space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-700 pb-20">
              <header className="px-2">
                <h2 className="text-4xl font-black tracking-tighter">Legal & Privacy</h2>
                <p className="text-zinc-500 font-bold italic mt-1">Our commitment to your data security.</p>
