              <div className="space-y-6">
                <Card className="p-8 rounded-[2.5rem] bg-white dark:bg-zinc-900 border-0 shadow-sm space-y-4">
                  <div className="flex items-center gap-3 text-emerald-500 mb-2">
                    <ShieldCheck className="h-6 w-6" />
                    <h3 className="font-black text-lg">Privacy Policy</h3>
                  </div>
                  <p className="text-xs font-bold text-zinc-500 leading-relaxed">
                    At InstaMunim, we value your privacy. Your sales data and customer information are encrypted and stored securely. We do not share your business data with any third-party aggregators.
                  </p>
                  <p className="text-xs font-bold text-zinc-500 leading-relaxed">
                    All voice data processed via the Smart Cashier is handled locally or via secure cloud APIs and is never recorded or stored for marketing purposes.
                  </p>
                </Card>

                <Card className="p-8 rounded-[2.5rem] bg-white dark:bg-zinc-900 border-0 shadow-sm space-y-4">
                  <div className="flex items-center gap-3 text-blue-500 mb-2">
                    <FileText className="h-6 w-6" />
                    <h3 className="font-black text-lg">Terms of Service</h3>
                  </div>
                  <ul className="space-y-3">
                    {[
                      "InstaMunim is a tool for billing and business management.",
                      "Users are responsible for accurate tax calculations and compliance.",
                      "The software is provided 'as-is' with focus on high availability.",
                      "Cloud sync requires a stable internet connection."
                    ].map((item, idx) => (
                      <li key={idx} className="flex gap-3 text-[10px] font-bold text-zinc-400 leading-snug">
                        <div className="w-1.5 h-1.5 rounded-full bg-zinc-300 mt-1 flex-shrink-0" />
                        {item}
                      </li>
                    ))}
                  </ul>
                </Card>

                <div className="text-center pt-4">
                  <p className="text-[10px] font-black text-zinc-300 uppercase tracking-widest">Version 2.0.4 - Enterprise Edition</p>
                </div>
              </div>
            </div>
          )}

          {activeTab === "MoreMenu" && (
            <div className="space-y-6 animate-in fade-in slide-in-from-bottom-4 duration-700 pb-28 px-4">
