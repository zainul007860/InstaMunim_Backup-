                        <Label className="text-[10px] font-black uppercase tracking-widest text-zinc-400">Dish Name</Label>
                        <Input placeholder="e.g. Paneer Tikka" value={newItemName} onChange={e => setNewItemName(e.target.value)} className="h-14 rounded-2xl bg-zinc-50 dark:bg-zinc-800 border-0 font-bold" />
                      </div>
                      <div className="space-y-2">
                        <Label className="text-[10px] font-black uppercase tracking-widest text-zinc-400">Price (₹)</Label>
                        <Input type="number" placeholder="0" value={newItemPrice} onChange={e => setNewItemPrice(e.target.value)} className="h-14 rounded-2xl bg-zinc-50 dark:bg-zinc-800 border-0 font-bold" />
                      </div>
                      <Button onClick={handleAddMenuItem} className="w-full h-16 bg-orange-500 hover:bg-orange-600 text-white font-black rounded-3xl text-lg shadow-xl shadow-orange-500/20">SAVE ITEM</Button>
                    </div>
                  </DialogContent>
                </Dialog>
              </header>

              <Card className="rounded-[2.5rem] border-0 shadow-sm overflow-hidden bg-white dark:bg-zinc-900">
                <div className="p-6 border-b dark:border-zinc-800 flex items-center gap-4">
                  <Search className="h-5 w-5 text-zinc-400" />
                  <Input 
                    placeholder="Search your menu..." 
                    className="border-0 bg-transparent font-bold text-lg p-0 h-auto focus-visible:ring-0"
                    value={itemSearch}
                    onChange={e => setItemSearch(e.target.value)}
                  />
                </div>
                <div className="divide-y dark:divide-zinc-800">
                  {menuItems.filter(item => item.name.toLowerCase().includes(itemSearch.toLowerCase())).map(item => (
