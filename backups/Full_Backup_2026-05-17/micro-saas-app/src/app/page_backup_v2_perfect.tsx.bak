                <p className="text-zinc-500 font-medium mt-1">Manage every aspect of your shop.</p>
              </div>

              <Card className="rounded-2xl border-0 bg-white dark:bg-zinc-900 shadow-sm divide-y dark:divide-zinc-800 overflow-hidden">
                {[
                  { id: "Settings", label: "Store Profile", sub: "Setup name, logo and rent", icon: Settings, color: "text-orange-500", bg: "bg-orange-50" },
                  { id: "Rent", label: "Performance Mission", sub: "Daily targets and growth", icon: TrendingUp, color: "text-blue-500", bg: "bg-blue-50" },
                  { id: "Marketing", label: "Smart CRM", sub: "Send offers on WhatsApp", icon: Send, color: "text-indigo-500", bg: "bg-indigo-50" },
                  { id: "Khata", label: "Udhaar Ledger", sub: "Manage customer credit", icon: Book, color: "text-red-500", bg: "bg-red-50" },
                  { id: "Legal", label: "Privacy & Terms", sub: "Legal documentation", icon: ShieldCheck, color: "text-emerald-500", bg: "bg-emerald-50" },
                  { id: "Support", label: "Expert Support", sub: "Chat with platform founder", icon: Smartphone, color: "text-emerald-500", bg: "bg-emerald-50" },
                ].map(item => (
                  <button 
                    key={item.id} 
                    onClick={() => setActiveTab(item.id)} 
                    className="w-full p-5 flex items-center justify-between hover:bg-zinc-50 dark:hover:bg-zinc-800/50 transition-all group"
                  >
                    <div className="flex items-center gap-4">
                      <div className={`w-12 h-12 rounded-xl flex items-center justify-center ${item.bg} dark:bg-opacity-10 group-hover:scale-110 transition-transform`}>
                        <item.icon className={`h-6 w-6 ${item.color}`} />
                      </div>
                      <div className="text-left">
                        <p className="font-bold text-sm leading-tight">{item.label}</p>
                        <p className="text-[10px] font-medium text-zinc-400 mt-1 uppercase tracking-wider">{item.sub}</p>
